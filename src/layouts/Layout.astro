---
export interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="I'm Samuel Corsan (disamdev), a full stack developer from Spain interested in coding since I was 9." />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="author" content="Samuel Corsan" />
		<meta name="keywords" content="Samuel Corsan, disamdev, full stack developer, web development, portfolio" />
		
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content="I'm Samuel Corsan (disamdev), a full stack developer from Spain interested in coding since I was 9." />
		<meta property="og:site_name" content="disamdev" />
		
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content="I'm Samuel Corsan (disamdev), a full stack developer from Spain interested in coding since I was 9." />
		<meta name="twitter:creator" content="@disamdev" />
		
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	html {
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		padding: 0;
		min-height: 100vh;
		background: #f8f9fa;
	}

	* {
		box-sizing: border-box;
	}

	:focus {
		outline: 2px solid #4299e1;
		outline-offset: 2px;
	}

	:focus:not(:focus-visible) {
		outline: none;
	}
</style>